# AI Model Configuration: copy ai-models.example.json to ai-models.json and edit

# Replay analysis model, used only by the replay one-click review endpoint
REPLAY_ANALYSIS_BASE_URL=https://api.example.com/v1
REPLAY_ANALYSIS_API_KEY=sk-your-replay-analysis-key
REPLAY_ANALYSIS_MODEL=your-review-model
REPLAY_ANALYSIS_TEMPERATURE=0.2
REPLAY_ANALYSIS_REASONING_EFFORT=max
REPLAY_ANALYSIS_THINKING=true
REPLAY_ANALYSIS_TIMEOUT_MS=300000

# Data storage
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ai_werewolf
REDIS_URL=redis://127.0.0.1:6379
SESSION_TTL_SECONDS=604800
ROOM_CACHE_TTL_SECONDS=3600

# Debug mode: allows stopping a game midway
# DEBUG=true

# NestJS log levels: comma-separated subset of log,error,warn,debug,verbose
# Default (when unset): log,error,warn — hides debug/verbose (incl. raw AI request bodies)
# Add 'debug' to inspect raw LLM request bodies; add 'verbose' for full trace
# LOG_LEVELS=log,error,warn

# Simulated human intensity for debug auto AI rooms: normal | high
# normal: natural low-info early game, gradual suspicion
# high: aggressive pressure-testing, current strong adversarial template
SIMULATED_HUMAN_INTENSITY=normal

# ============================================================================
# 沙盒评测并发(每个成本层同时最多几局对局在跑)
# ============================================================================
# 【并发怎么控制的】
#   每评测一个提示词版本 = 起一个固定大小的 worker 池(见 shared/concurrency.ts):
#   池大小 = 下面对应成本层的值;每个 worker 领一局 → 跑完整局(讨论 + 裁判打分)
#   → 再领下一局,谁先跑完谁先补位。所以「池大小」= 任一时刻最多几局并发。
#   多个版本(如对照测试的 父/空/负/正)是【顺序】评测的,池一个接一个开,
#   因此这个值也是整场评测任一瞬间的【全局】对局并发上限,不是每臂各一份。
#
# 【成本层怎么自动选】(scheduler.ts:resolveCostTier,优先级从上到下)
#   - 显式传 cost_tier → 用它
#   - diagnose=true            → diagnostic(诊断评测)
#   - judgeModelIds 传了 2+ 个 → calibration(多裁判校准评测)
#   - 以上都没有(默认)       → decision(决策评测)
#   ★ 对照测试(control test)恒定走 decision:它只用单裁判、不诊断,
#     所以只受 SANDBOX_DECISION_CONCURRENCY 影响,另外两个对它无效。
#
# 【三层分别在做啥 + 为什么默认并发递减】
#   每局的 LLM 调用量随层不同,默认并发反向递减,好让打向模型端点的总负载可控。
#   - decision(决策):默认路径。每局只在局末跑【一次】单裁判盲测打分,判 promote/
#       reject。最便宜 → 默认并发 3。
#   - diagnostic(诊断):纵向深挖【单局】——查这局 AI 哪轮/哪维/哪句露馅,喂优化器。
#       每局要多跑「逐轮可疑度轨迹 + 八维量表诊断裁判」,LLM 调用翻几倍 → 默认并发 2。
#       关注的是 AI 错在哪。
#   - calibration(校准):横向让【同一局】N 个不同模型的裁判各打一遍,截尾均值聚合 +
#       算裁判一致度(judge_agreement),用来验裁判本身可不可信、防优化器专钻某一个裁判。
#       每局 = N× 裁判调用 → 默认并发 1。关注的是裁判可不可信。
#
# 【取值规则】正整数;不设或非法 → 用各自默认值。
#   调高提升吞吐,但会成比例放大对 ai-models.json 里 default 端点的 QPS,别超端点限流。
# ----------------------------------------------------------------------------
# SANDBOX_DECISION_CONCURRENCY=3     # 决策层(默认 3)—— 对照测试用的就是这个
# SANDBOX_DIAGNOSTIC_CONCURRENCY=2   # 诊断层(默认 2)—— 编排器 diagnose=true 时
# SANDBOX_CALIBRATION_CONCURRENCY=1  # 校准层(默认 1)—— 编排器传 2+ 个裁判模型时
