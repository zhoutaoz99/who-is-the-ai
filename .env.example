# AI Model Configuration (OpenAI compatible API)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_TIMEOUT_MS=15000
AI_REASONING_EFFORT=high

# Optional per-layer overrides. Empty means falling back to AI_MODEL / AI_TEMPERATURE / AI_REASONING_EFFORT.
# AI_STRATEGY_MODEL=gpt-4o-mini
# AI_STRATEGY_TEMPERATURE=0.6
# AI_STRATEGY_REASONING_EFFORT=high
# AI_EXPRESSION_MODEL=gpt-4o-mini
# AI_EXPRESSION_TEMPERATURE=0.9
# AI_EXPRESSION_REASONING_EFFORT=medium

# Data storage
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ai_werewolf
REDIS_URL=redis://127.0.0.1:6379
SESSION_TTL_SECONDS=604800
ROOM_CACHE_TTL_SECONDS=3600
