# AI Model Configuration: copy ai-models.example.json to ai-models.json and edit

# Replay analysis model, used only by the replay one-click review endpoint
REPLAY_ANALYSIS_BASE_URL=https://api.example.com/v1
REPLAY_ANALYSIS_API_KEY=sk-your-replay-analysis-key
REPLAY_ANALYSIS_MODEL=your-review-model
REPLAY_ANALYSIS_TEMPERATURE=0.2
REPLAY_ANALYSIS_REASONING_EFFORT=max
REPLAY_ANALYSIS_THINKING=true
REPLAY_ANALYSIS_TIMEOUT_MS=300000

# Data storage
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ai_werewolf
REDIS_URL=redis://127.0.0.1:6379
SESSION_TTL_SECONDS=604800
ROOM_CACHE_TTL_SECONDS=3600

# Debug mode: allows stopping a game midway
# DEBUG=true

# NestJS log levels: comma-separated subset of log,error,warn,debug,verbose
# Default (when unset): log,error,warn — hides debug/verbose (incl. raw AI request bodies)
# Add 'debug' to inspect raw LLM request bodies; add 'verbose' for full trace
# LOG_LEVELS=log,error,warn

# Simulated human intensity for debug auto AI rooms: normal | high
# normal: natural low-info early game, gradual suspicion
# high: aggressive pressure-testing, current strong adversarial template
SIMULATED_HUMAN_INTENSITY=normal
